model User {
    id        String     @id @default(ulid())
    phone      String     @db.VarChar(15)
    email     String     @unique
    password_hashed  String
    status    UserStatus @default(ACTIVE)
    role      Role       @default(TENANT)
    created_at DateTime   @default(now())
    updated_at DateTime   @updatedAt
    deleted_at DateTime?
    profile   Profile?
    
    @@index([email])
    @@map("users")
}

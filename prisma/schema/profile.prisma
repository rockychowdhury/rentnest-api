model Profile {
    id           String  @id @default(uuid())
    full_name String @db.VarChar(100)
    avatar_url String?
    bio          String?
    gender Gender?
    occupation String?

    user_id String @unique
    user   User   @relation(fields: [user_id], references: [id])

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}